#!/usr/bin/env bash
#
# upgrade-codex - Select the newest Codex release and delegate its package
# installation to the official installer shipped with that release.

set -euo pipefail

DRY_RUN=false
CLEAN_ONLY=false
KEEP_VERSIONS=3

for arg in "$@"; do
    case "$arg" in
        --dry-run|-n) DRY_RUN=true ;;
        --clean|-c)   CLEAN_ONLY=true ;;
        *) echo "Unknown option: $arg" >&2; exit 1 ;;
    esac
done

: "${HOME:?HOME is required}"

XDG_BIN_HOME="${XDG_BIN_HOME:-$HOME/.local/bin}"
XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
PATH="$XDG_BIN_HOME:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin${PATH:+:$PATH}"
export PATH

GITHUB_API="${CODEX_GITHUB_API:-https://api.github.com/repos/openai/codex/releases}"
LOG_FILE="${CODEX_LOG_FILE:-$XDG_DATA_HOME/codex/update.log}"
STANDALONE_ROOT="${CODEX_STANDALONE_ROOT:-${CODEX_HOME:-$HOME/.codex}/packages/standalone}"
RELEASES_DIR="$STANDALONE_ROOT/releases"

case "$(uname -m):$(uname -s)" in
    x86_64:Linux) CODEX_TARGET="${CODEX_TARGET:-x86_64-unknown-linux-musl}" ;;
    aarch64:Linux|arm64:Linux) CODEX_TARGET="${CODEX_TARGET:-aarch64-unknown-linux-musl}" ;;
    *) echo "Unsupported Codex platform: $(uname -m) $(uname -s)" >&2; exit 1 ;;
esac
PACKAGE_ASSET="codex-package-$CODEX_TARGET.tar.gz"

prepare_log_file() {
    local fallback_log="$XDG_DATA_HOME/ai-updaters/codex-update.log"
    local log_dir

    log_dir="$(dirname "$LOG_FILE")"
    if mkdir -p "$log_dir" 2>/dev/null && { [[ ! -e "$LOG_FILE" ]] || [[ -w "$LOG_FILE" ]]; } && [[ -w "$log_dir" ]]; then
        return
    fi

    LOG_FILE="$fallback_log"
    mkdir -p "$(dirname "$LOG_FILE")"
}

log() {
    local msg
    msg="$(date '+%Y-%m-%d %H:%M:%S') $1"
    echo "$msg" >> "$LOG_FILE"
    echo "$msg"
}

release_in_use() {
    local release_dir="$1"
    local exe_link exe_path

    release_dir="$(readlink -f "$release_dir")" || return 1
    for exe_link in /proc/[0-9]*/exe; do
        exe_path="$(readlink "$exe_link" 2>/dev/null)" || continue
        if [[ "$exe_path" == "$release_dir/"* ]]; then
            return 0
        fi
    done

    return 1
}

cleanup_old_versions() {
    local -a versions=()
    local current=""

    [[ -L "$STANDALONE_ROOT/current" ]] && current="$(readlink -f "$STANDALONE_ROOT/current")"
    while IFS= read -r dir; do
        versions+=("$dir")
    done < <(find "$RELEASES_DIR" -mindepth 1 -maxdepth 1 -type d ! -name '.staging.*' \
        -printf '%T@ %p\n' 2>/dev/null | sort -rn | cut -d' ' -f2-)

    if (( ${#versions[@]} <= KEEP_VERSIONS )); then
        log "[CLEAN] ${#versions[@]} release(s) present; keeping $KEEP_VERSIONS"
        return
    fi

    local dir
    for dir in "${versions[@]:$KEEP_VERSIONS}"; do
        if [[ "$(readlink -f "$dir")" == "$current" ]]; then
            continue
        fi
        if release_in_use "$dir"; then
            log "[CLEAN] Keeping active release: $(basename "$dir")"
            continue
        fi
        if $DRY_RUN; then
            log "[DRY-RUN] Would remove release: $(basename "$dir")"
        else
            log "[CLEAN] Removing inactive release: $(basename "$dir")"
            rm -rf "$dir"
        fi
    done
}

version_gt() {
    local highest
    highest="$(printf '%s\n%s\n' "$1" "$2" | sort -V | tail -1)"
    [[ "$highest" == "$1" && "$1" != "$2" ]]
}

prepare_log_file
mkdir -p "$RELEASES_DIR"

if $CLEAN_ONLY; then
    cleanup_old_versions
    exit 0
fi

current_version="$(codex --version 2>/dev/null | sed -n 's/.* \([0-9][0-9A-Za-z.+-]*\)$/\1/p' | head -1 || true)"
package_install=false
if [[ -L "$STANDALONE_ROOT/current" ]] \
    && [[ -x "$STANDALONE_ROOT/current/bin/codex" ]] \
    && [[ -x "$STANDALONE_ROOT/current/bin/codex-code-mode-host" ]] \
    && [[ -x "$STANDALONE_ROOT/current/codex-path/rg" ]]; then
    package_install=true
fi

if ! json_body="$(curl -fsSL --max-time 30 \
    -H 'Accept: application/vnd.github+json' \
    "$GITHUB_API?per_page=20")"; then
    log "[ERROR] Could not fetch Codex release metadata"
    exit 1
fi

mapfile -t candidate_pairs < <(jq -r --arg package "$PACKAGE_ASSET" '
    .[] | select(.draft == false)
    | select(any(.assets[]; .name == "install.sh"))
    | select(any(.assets[]; .name == $package))
    | [.tag_name, (.tag_name | sub("^rust-v"; ""))] | @tsv
' <<<"$json_body")

if (( ${#candidate_pairs[@]} == 0 )); then
    log "[ERROR] No installable Codex package releases found"
    exit 1
fi

latest_tag="${candidate_pairs[0]%%$'\t'*}"
latest_version="${candidate_pairs[0]##*$'\t'}"
for pair in "${candidate_pairs[@]:1}"; do
    version="${pair##*$'\t'}"
    if version_gt "$version" "$latest_version"; then
        latest_tag="${pair%%$'\t'*}"
        latest_version="$version"
    fi
done

log "[DEBUG] Latest package version: '$latest_version' | Current installed: '${current_version:-<none>}' | Package layout: '$package_install'"
if [[ "$latest_version" == "$current_version" ]] && $package_install; then
    log "[OK] Codex $current_version is up to date"
    $DRY_RUN && cleanup_old_versions
    exit 0
fi
if [[ -n "$current_version" && "$latest_version" != "$current_version" ]] \
    && ! version_gt "$latest_version" "$current_version"; then
    log "[OK] Current $current_version >= latest $latest_version, nothing to do"
    $DRY_RUN && cleanup_old_versions
    exit 0
fi

installer_url="$(jq -r --arg tag "$latest_tag" '
    .[] | select(.tag_name == $tag) | .assets[]
    | select(.name == "install.sh") | .browser_download_url
' <<<"$json_body" | head -1)"
installer_digest="$(jq -r --arg tag "$latest_tag" '
    .[] | select(.tag_name == $tag) | .assets[]
    | select(.name == "install.sh") | .digest
' <<<"$json_body" | head -1)"
if [[ -z "$installer_url" || "$installer_url" == "null" \
    || ! "$installer_digest" =~ ^sha256:[0-9a-fA-F]{64}$ ]]; then
    log "[ERROR] Official installer not found for $latest_tag"
    exit 1
fi

if $DRY_RUN; then
    log "[DRY-RUN] Would update Codex: ${current_version:-none} -> $latest_version"
    cleanup_old_versions
    exit 0
fi

log "[UPDATE] Updating Codex package: ${current_version:-none} -> $latest_version"
tmpdir="$(mktemp -d)"
trap 'rm -rf "$tmpdir"' EXIT
installer="$tmpdir/install.sh"
curl -fsSL --max-time 60 -o "$installer" "$installer_url"
echo "${installer_digest#sha256:}  $installer" | sha256sum --check --status

CODEX_INSTALL_DIR="$XDG_BIN_HOME" \
CODEX_NON_INTERACTIVE=1 \
CODEX_RELEASE="$latest_version" \
    sh "$installer"

installed_version="$(codex --version 2>/dev/null | sed -n 's/.* \([0-9][0-9A-Za-z.+-]*\)$/\1/p' | head -1 || true)"
if [[ "$installed_version" != "$latest_version" ]]; then
    log "[ERROR] Installed Codex version '$installed_version' does not match '$latest_version'"
    exit 1
fi

log "[SUCCESS] Codex package updated: ${current_version:-none} -> $latest_version"
cleanup_old_versions
