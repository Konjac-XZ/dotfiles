# Machine-local overrides for Codex, Claude Code, and OpenCode update timers.
# This file is optional; the systemd user units and scripts work without it.

{{- if hasKey . "proxy" }}
{{- with .proxy }}
{{- if and (hasKey . "enabled") .enabled (hasKey . "scheme") (hasKey . "host") (hasKey . "port") (hasKey . "no_proxy") }}
{{- $proxy := printf "%s://%s:%d" .scheme .host .port }}
HTTP_PROXY={{ $proxy }}
HTTPS_PROXY={{ $proxy }}
ALL_PROXY={{ $proxy }}
NO_PROXY={{ .no_proxy }}

http_proxy={{ $proxy }}
https_proxy={{ $proxy }}
all_proxy={{ $proxy }}
no_proxy={{ .no_proxy }}
{{- end }}
{{- end }}
{{- end }}

# Optional examples:
# CODEX_TARGET=x86_64-unknown-linux-musl
# CODEX_INSTALL_DIR=/custom/bin
# CLAUDE_BIN=/custom/bin/claude
# OPENCODE_BIN=/custom/bin/opencode
# OPENCODE_UPGRADE_METHOD=curl
