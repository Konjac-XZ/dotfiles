{{- if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
set -u

LINUXBREW_ROOT="/home/linuxbrew/.linuxbrew"

# ---- Ensure only the Linuxbrew owner runs this ----
if [ "${EUID:-$(id -u)}" -eq 0 ]; then
  echo "[chezmoi] INFO: Root user detected. Skipping Homebrew package installation."
  exit 0
fi

if [ ! -d "$LINUXBREW_ROOT" ]; then
  echo "[chezmoi] INFO: $LINUXBREW_ROOT not found. Skipping Homebrew package installation."
  exit 0
fi

LINUXBREW_OWNER_UID="$(stat -c '%u' "$LINUXBREW_ROOT" 2>/dev/null || true)"
if [ -z "$LINUXBREW_OWNER_UID" ] || [ "${EUID:-$(id -u)}" -ne "$LINUXBREW_OWNER_UID" ]; then
  echo "[chezmoi] INFO: Current user is not the Linuxbrew owner. Skipping Homebrew package installation."
  exit 0
fi

# ---- Activate Homebrew without relying on .zshrc ----
BREW="$LINUXBREW_ROOT/bin/brew"

if [ ! -x "$BREW" ]; then
  echo "[chezmoi] INFO: brew not found under $LINUXBREW_ROOT; skipping package installation."
  exit 0
fi

# Put brew + its paths into this process environment
BREW_ENV="$($BREW shellenv 2>/dev/null || true)"
if [ -z "$BREW_ENV" ]; then
  echo "[chezmoi] INFO: Failed to initialize brew environment. Skipping package installation."
  exit 0
fi
eval "$BREW_ENV"

# Homebrew defaults to ask mode for installs; make chezmoi runs unattended.
export HOMEBREW_NO_ASK=1

# Ensure brew bundle exists
if ! brew help bundle >/dev/null 2>&1; then
  brew tap homebrew/bundle >/dev/null 2>&1 || true
fi

# ---- Install declared packages ----
FAILED=0
CHECK_DIR="$(mktemp -d "${TMPDIR:-/tmp}/chezmoi-brew-check.XXXXXX")"
trap 'rm -rf "$CHECK_DIR"' EXIT

declare -a CHECK_TYPES=()
declare -a CHECK_PACKAGES=()
declare -a CHECK_FILES=()
declare -a CHECK_PIDS=()

FORMULA_CHECKS=0
CASK_CHECKS=0

queue_check() {
  local type="$1"
  local package="$2"
  local index="${#CHECK_PACKAGES[@]}"
  local result_file="$CHECK_DIR/$index.status"

  CHECK_TYPES[$index]="$type"
  CHECK_PACKAGES[$index]="$package"
  CHECK_FILES[$index]="$result_file"

  case "$type" in
    formula)
      FORMULA_CHECKS=$((FORMULA_CHECKS + 1))
      (brew list --formula "$package" >/dev/null 2>&1 && printf 'installed\n' >"$result_file" || printf 'missing\n' >"$result_file") &
      ;;
    cask)
      CASK_CHECKS=$((CASK_CHECKS + 1))
      (brew list --cask "$package" >/dev/null 2>&1 && printf 'installed\n' >"$result_file" || printf 'missing\n' >"$result_file") &
      ;;
    *)
      echo "[chezmoi] ERROR: unsupported Homebrew package type: $type" >&2
      return 1
      ;;
  esac

  CHECK_PIDS[$index]=$!
}

install_missing_brew() {
  local package="$1"

  if brew list --formula "$package" >/dev/null 2>&1; then
    echo "[chezmoi] OK: brew package already installed after dependency install: $package"
    return 0
  fi

  echo "[chezmoi] INSTALL: brew package: $package"
  if brew install "$package"; then
    echo "[chezmoi] OK: installed brew package: $package"
  else
    echo "[chezmoi] ERROR: failed to install brew package: $package" >&2
    return 1
  fi
}

install_missing_cask() {
  local package="$1"

  if brew list --cask "$package" >/dev/null 2>&1; then
    echo "[chezmoi] OK: cask already installed after dependency install: $package"
    return 0
  fi

  echo "[chezmoi] INSTALL: cask: $package"
  if brew install --cask "$package"; then
    echo "[chezmoi] OK: installed cask: $package"
  else
    echo "[chezmoi] ERROR: failed to install cask: $package" >&2
    return 1
  fi
}

{{- range .packages.linux.brews }}
queue_check formula {{ . | quote }} || FAILED=1
{{- end }}
{{- range .packages.linux.casks }}
queue_check cask {{ . | quote }} || FAILED=1
{{- end }}

echo "[chezmoi] CHECK: queued Homebrew package checks: $FORMULA_CHECKS formula(s), $CASK_CHECKS cask(s)."

for index in "${!CHECK_PIDS[@]}"; do
  if ! wait "${CHECK_PIDS[$index]}"; then
    echo "[chezmoi] ERROR: Homebrew check failed: ${CHECK_TYPES[$index]} ${CHECK_PACKAGES[$index]}" >&2
    printf 'error\n' >"${CHECK_FILES[$index]}"
    FAILED=1
  fi
done

for index in "${!CHECK_PACKAGES[@]}"; do
  type="${CHECK_TYPES[$index]}"
  package="${CHECK_PACKAGES[$index]}"
  result="$(cat "${CHECK_FILES[$index]}" 2>/dev/null || printf 'error\n')"

  case "$result" in
    installed)
      case "$type" in
        formula)
          echo "[chezmoi] OK: brew package already installed: $package"
          ;;
        cask)
          echo "[chezmoi] OK: cask already installed: $package"
          ;;
      esac
      ;;
    missing)
      case "$type" in
        formula)
          install_missing_brew "$package" || FAILED=1
          ;;
        cask)
          install_missing_cask "$package" || FAILED=1
          ;;
      esac
      ;;
    *)
      echo "[chezmoi] ERROR: Homebrew check produced an invalid result: $type $package" >&2
      FAILED=1
      ;;
  esac
done

if [ "$FAILED" -ne 0 ]; then
  echo "[chezmoi] ERROR: one or more Homebrew packages failed to install." >&2
  exit 1
fi

echo "[chezmoi] OK: Homebrew package installation check completed."
{{- end -}}
